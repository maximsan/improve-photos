# electron-builder's app-builder packs node_modules from a flat npm-style
# layout. pnpm's default symlinked layout (with deps under .pnpm/) causes
# transitive deps like `ms` (a sibling of `debug` for `electron-updater`) to
# go missing from the packed app.asar, crashing the main process at launch
# with "Cannot find module 'ms'". shamefully-hoist=true makes pnpm hoist
# every dependency to the top of node_modules — slower and less strict than
# default pnpm, but matches what electron-builder expects.
shamefully-hoist=true
